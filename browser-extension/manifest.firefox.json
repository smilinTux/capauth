{
  "manifest_version": 2,
  "name": "CapAuth - Sovereign Login",
  "short_name": "CapAuth",
  "version": "0.1.0",
  "description": "One-click passwordless PGP login for sovereign services",
  "author": "smilinTux",
  "homepage_url": "https://capauth.io",

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "https://*.capauth.io/*",
    "https://*.skworld.io/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.capauth.io/*",
        "https://*.skworld.io/*"
      ],
      "js": [
        "content_scripts/detector.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "CapAuth - Sovereign Login",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    "icons/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "capauth@smilintux.org",
      "strict_min_version": "115.0"
    }
  }
}
