# CapAuth Service — environment configuration
# Copy to .env and fill in values before running docker compose

# Service identity
CAPAUTH_SERVICE_ID=capauth.local
CAPAUTH_BASE_URL=http://localhost:8420
CAPAUTH_PORT=8420

# Security — CHANGE THESE before production
CAPAUTH_ADMIN_TOKEN=change-me-admin-token-min-32-chars
CAPAUTH_JWT_SECRET=change-me-jwt-secret-at-least-32-chars

# Key enrollment: "false" = auto-approve, "true" = require admin approval
CAPAUTH_REQUIRE_APPROVAL=false

# Optional: server PGP key (base64-encoded ASCII armor)
# Generate with: gpg --export-secret-key --armor <FP> | base64 -w0
# CAPAUTH_SERVER_KEY_ARMOR=
# CAPAUTH_SERVER_KEY_PASSPHRASE=
