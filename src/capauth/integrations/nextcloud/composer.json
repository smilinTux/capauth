{
    "name": "capauth/nextcloud-app",
    "description": "CapAuth passwordless PGP login for Nextcloud",
    "type": "nextcloud-app",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "OCA\\CapAuth\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\CapAuth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "stan": "phpstan analyse lib tests --level 6",
        "cs": "phpcs --standard=PSR12 lib/ tests/"
    }
}
